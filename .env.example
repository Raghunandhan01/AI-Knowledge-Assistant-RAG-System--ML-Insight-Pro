# --- ML Insight Pro Configuration ---

# 1. GEMINI_API_KEY (REQUIRED)
# Get your free API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY="YOUR_ACTUAL_API_KEY_HERE"

# 2. APP_URL (Optional for local)
# The URL where this app is hosted.
APP_URL="http://localhost:3000"

# --- Instructions ---
# 1. Create a file named ".env" in this root directory.
# 2. Copy the contents of this file into ".env".
# 3. Replace "YOUR_ACTUAL_API_KEY_HERE" with your real Gemini API key.
